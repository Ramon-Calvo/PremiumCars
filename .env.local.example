# ============================================================
# ReportMotor Sales — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# ============================================================

# ------ Supabase (OBLIGATORIO) --------------------------------
# Obtenlos en https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------ WhatsApp flotante (OBLIGATORIO) -----------------------
# Número en formato internacional sin + (ej: 34604955023)
NEXT_PUBLIC_WHATSAPP_NUMBER=34604955023

# ------ Email con Resend (OPCIONAL) ---------------------------
# Si no se configura, los formularios guardan datos en Supabase
# pero no envían emails de notificación.
# Obtén tu API key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email al que llegan las notificaciones de admin
ADMIN_EMAIL=hola@reportmotor.es

# Dirección "from" verificada en Resend (debe ser de tu dominio)
EMAIL_FROM=notificaciones@reportmotor.es

# ------ URL pública del sitio (OBLIGATORIO en producción) -----
# Necesario para generar el sitemap.xml correctamente
NEXT_PUBLIC_SITE_URL=https://www.reportmotor.es
